# =============================================================================
# LOCAL DEVELOPMENT — copy to frontend/.env.local
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:5000

# Must match backend GOOGLE_CLIENT_ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: used by next.config.mjs to proxy /uploads in dev
# API_PROXY_TARGET=http://localhost:5000

# =============================================================================
# PRODUCTION (Vercel) — optional; same domain serves /api automatically.
# Only set NEXT_PUBLIC_API_URL if the API runs on a different host.
#   NEXT_PUBLIC_GOOGLE_CLIENT_ID=<same as backend GOOGLE_CLIENT_ID>
# Add your Vercel URL to Google OAuth authorized origins.
# Backend env vars (MONGODB_URI, JWT_SECRET, etc.) also go in Vercel settings.
# =============================================================================
