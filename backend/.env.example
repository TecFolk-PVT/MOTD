# =============================================================================
# LOCAL DEVELOPMENT — copy to backend/.env
# Uses your local MongoDB instance (mongodb://127.0.0.1:27017/motd)
# =============================================================================

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/motd
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google Sign-In (customers only)
# Authorized JavaScript origins: http://localhost:3000
GOOGLE_CLIENT_ID=

# Gmail SMTP for forgot-password emails (use a Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# PRODUCTION (Vercel) — set in Vercel project → Settings → Environment Variables
# Same project hosts frontend + API; NEXT_PUBLIC_API_URL is not required.
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/motd?retryWrites=true&w=majority
#   CORS_ORIGIN=https://your-app.vercel.app
#   FRONTEND_URL=https://your-app.vercel.app
#   NODE_ENV=production
#   JWT_SECRET=<long random string>
#   GOOGLE_CLIENT_ID=...
#   NEXT_PUBLIC_GOOGLE_CLIENT_ID=... (same as GOOGLE_CLIENT_ID)
# =============================================================================
